{
  "name": "common-knowledge-hub",
  "version": "0.1.0",
  "description": "Nervos CKB stack launcher — full node, Fiber, light client, mining proxy, dashboards",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder",
    "build:linux-arm64": "electron-builder --linux --arm64",
    "build:linux-x64": "electron-builder --linux --x64",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win"
  },
  "build": {
    "appId": "com.wyltek.ckh",
    "productName": "Common Knowledge Hub",
    "copyright": "Copyright © 2026 Wyltek Industries",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "node_modules/**/*"
    ],
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "Network",
      "icon": "assets/icon.png"
    },
    "mac": {
      "target": ["dmg"],
      "icon": "assets/icon.icns"
    },
    "win": {
      "target": ["nsis"],
      "icon": "assets/icon.ico"
    }
  },
  "keywords": ["nervos", "ckb", "fiber", "blockchain", "node"],
  "author": "Wyltek Industries <hello@wyltekindustries.com>",
  "license": "MIT",
  "devDependencies": {
    "electron": "^34.0.0",
    "electron-builder": "^25.0.0"
  },
  "dependencies": {
    "node-pty": "^1.0.0"
  }
}
